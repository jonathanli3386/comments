# Backend configuration — copy to `.env` to override. All values are optional;
# the defaults below let the API run locally with no configuration.

# Comma-separated origins allowed to call the API (the Next.js dev server).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Secret key and debug flag — override these in production.
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
